{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "technical-route": {
        "ClusterId": "technical-cluster",
        "Match": {
          "Path": "/api/technical/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "routing-route": {
        "ClusterId": "routing-cluster",
        "Match": {
          "Path": "/api/routing/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "personnel-route": {
        "ClusterId": "personnel-cluster",
        "Match": {
          "Path": "/api/personnel/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "aggregator-route": {
        "ClusterId": "aggregator-cluster",
        "Match": {
          "Path": "/api/aggregator/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "technical-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://technicalservice-api"
          }
        }
      },
      "routing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://routing-api"
          }
        }
      },
      "personnel-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://personnel-api"
          }
        }
      },
      "aggregator-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://aggregator"
          }
        }
      }
    }
  }
}